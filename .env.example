# ── Supabase (RSVP storage) ────────────────────────────────────────────────
# Supabase dashboard → Project Settings → API
SUPABASE_URL=https://YOUR-PROJECT.supabase.co

# SECRET — service-role / secret key (sb_secret_...). Server-only; never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-secret-key

# ── Admin dashboard (/admin) ───────────────────────────────────────────────
# The single shared password used to view RSVPs.
ADMIN_PASSWORD=choose-a-strong-password

# Random string used to sign the admin session cookie (e.g. `openssl rand -hex 32`).
ADMIN_SESSION_SECRET=replace-with-a-long-random-string

# ── Registry (gift list + email-verified "mark as purchased") ──────────────
# Signs the confirm/release links emailed to guests (e.g. `openssl rand -hex 32`).
# Optional — falls back to ADMIN_SESSION_SECRET if unset.
REGISTRY_TOKEN_SECRET=replace-with-a-long-random-string
# Note: the registry reuses the Supabase + Resend + SITE_URL config below.
# Run supabase/schema.sql to create the registry_items / registry_claims tables.

# ── Confirmation emails (Resend) ───────────────────────────────────────────
# Optional. If unset, RSVPs still save — guests just don't get a confirmation.
# API key: resend.com/api-keys
RESEND_API_KEY=re_your_api_key
# Verified sender on your domain. Must be a domain verified in Resend.
RESEND_FROM=Your Names <rsvp@yourdomain.com>
# Public site URL — used to build "change response" / calendar links in emails.
# Set to your production domain; use http://localhost:3000 for local testing.
SITE_URL=https://yourdomain.com

# ── SMS sender (/admin/sms) ────────────────────────────────────────────────
# No provider/API key needed: texts are sent from YOUR number via the Mac's
# Messages app, so this only works when you run the admin locally (npm run dev)
# on a Mac signed into Messages. For SMS to Android guests, enable Text Message
# Forwarding on the paired iPhone (Settings → Messages → Text Message Forwarding).
# Milliseconds to wait between each send so a burst isn't flagged as spam (default 2000).
SMS_THROTTLE_MS=2000

# ── Home page directory buttons (/) ────────────────────────────────────────
# Each button shows unless its flag is set to "false".
NAV_SAVE_THE_DATE=true
NAV_LOCATION_TIME=true
NAV_DRESS_CODE=true
NAV_RSVP=true
NAV_REGISTRY=true

# ── Location & Time recommendations ────────────────────────────────────────
# Overnight-stay note on /location is OPT-IN (often shown to family only).
# It stays hidden unless this is exactly "true". Leave unset/commented to hide.
RECOMMEND_LODGING=true
