# ── Supabase (RSVP storage) ────────────────────────────────────────────────
# Supabase dashboard → Project Settings → API
SUPABASE_URL=https://YOUR-PROJECT.supabase.co

# SECRET — service-role / secret key (sb_secret_...). Server-only; never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-secret-key

# ── Admin dashboard (/admin) ───────────────────────────────────────────────
# The single shared password used to view RSVPs.
ADMIN_PASSWORD=choose-a-strong-password

# Random string used to sign the admin session cookie (e.g. `openssl rand -hex 32`).
ADMIN_SESSION_SECRET=replace-with-a-long-random-string

# ── Confirmation emails (Resend) ───────────────────────────────────────────
# Optional. If unset, RSVPs still save — guests just don't get a confirmation.
# API key: resend.com/api-keys
RESEND_API_KEY=re_your_api_key
# Verified sender on your domain. Must be a domain verified in Resend.
RESEND_FROM=Your Names <rsvp@yourdomain.com>
# Public site URL — used to build "change response" / calendar links in emails.
# Set to your production domain; use http://localhost:3000 for local testing.
SITE_URL=https://yourdomain.com

# ── Home page directory buttons (/) ────────────────────────────────────────
# Each button shows unless its flag is set to "false".
NAV_SAVE_THE_DATE=true
NAV_LOCATION_TIME=true
NAV_DRESS_CODE=true
NAV_REGISTRY=true
# Optional external registry URL for the "Registry & Gifts" button.
REGISTRY_URL=https://www.zola.com/registry/your-registry
