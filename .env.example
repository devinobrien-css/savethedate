# ── Supabase (RSVP storage) ────────────────────────────────────────────────
# Supabase dashboard → Project Settings → API
SUPABASE_URL=https://YOUR-PROJECT.supabase.co

# SECRET — service-role / secret key (sb_secret_...). Server-only; never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-secret-key

# ── Admin dashboard (/admin) ───────────────────────────────────────────────
# The single shared password used to view RSVPs.
ADMIN_PASSWORD=choose-a-strong-password

# Random string used to sign the admin session cookie (e.g. `openssl rand -hex 32`).
ADMIN_SESSION_SECRET=replace-with-a-long-random-string
